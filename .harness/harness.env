# scripts/harness.env — config for the in-place Ralph loop (sourced by loop.sh).
#
# Precedence:  real environment  >  this file  >  loop.sh built-in default
# (the `: "${VAR:=…}"` form only assigns when VAR is unset).

# ─── Model (COLD-START FLOOR — cheapest tier; the policy tunes UP from here) ──
# Tasks no longer carry per-task model/effort; the policy picks each task's start tier from
# facets + the outcomes ledger, cold-starting at this floor. Pin the FULL id (the bare alias drifts).
: "${MODEL:=claude-sonnet-4-6}"
: "${EFFORT:=low}"        # low|medium|high|xhigh|max — cheapest by default (bias-cheap; the ladder escalates)

# ─── Caps & cadence ──────────────────────────────────────────────────────────
: "${MAX_ATTEMPTS:=2}"     # soft failures per rung before escalating (global ladder is fine-grained, so fewer tries per rung bounds the attempt budget)
: "${MAX_ITERS:=100}"      # global iteration backstop per run
: "${WAIT_SECONDS:=30}"    # backoff between retries / CI polls
: "${CI_TIMEOUT:=1200}"    # max seconds to wait for a CI run

# ─── CI gate ─────────────────────────────────────────────────────────────────
: "${CI_WORKFLOW:=CI}"     # MUST equal `name:` in .github/workflows/ci.yml
: "${REQUIRE_CI:=1}"       # 1 = never mark a task done without green CI on main
: "${MAIN_BRANCH:=main}"

# ─── Self-healing repo state (this checkout is OWNED by the loop) ────────────
# On a DIRTY tree at startup (almost always orphaned partial work from an attempt killed mid-build —
# e.g. a usage-limit interrupt — NOT human work), auto-STASH it (timestamped, recoverable via
# `git stash list`) then hard-reset to origin/$MAIN_BRANCH, so an unattended run can ALWAYS start
# instead of refusing forever. Set 0 to restore the protective "refuse on dirty tree" behaviour
# (correct for a checkout you also hand-edit). Default ON here: this is a dedicated loop checkout.
: "${LOOP_AUTORESET:=1}"

# ─── Local Definition-of-Done gate (cheap, runs BEFORE the paid audit) ────────
# The loop's structural_checks runs this in the checkout before the blocking audit, so a build
# that doesn't compile / pass tests never reaches the (paid) auditor. Mirror CI's core checks.
# See .harness/designs/audit-verification.md §4.2.
: "${LOCAL_DOD:=npx tsc --noEmit && npm test}"

# ─── Claude usage-limit backoff (pause + cold re-attempt) ────────────────────
# When `claude` hits the usage/session limit, the loop SLEEPS then RE-ATTEMPTS the same task COLD
# (not a failure — every attempt is a fresh cold pass; §4.1). Two paths:
#  • KNOWN reset — Claude prints e.g. "resets 3:10pm (Europe/London)" → sleep until that time +
#    RL_BUFFER, then resume (the common case; this is why we don't blindly retry every few minutes).
#  • UNKNOWN reset (unparseable wording) → exponential backoff from RL_BACKOFF_MIN, doubling, capped
#    at RL_EXP_MAX.
: "${RL_BACKOFF_MIN:=300}"     # exponential-fallback FIRST backoff: 5 min
: "${RL_EXP_MAX:=3600}"        # exponential-fallback CAP: 1h (UNKNOWN-reset path only)
: "${RL_BACKOFF_MAX:=18000}"   # cap for a PARSED reset wait (~5h — a known reset can be hours away)
: "${RL_BUFFER:=300}"          # resume this many seconds AFTER a parsed reset time (5-min cushion)

# NOTE: jq + gh are required (brew install jq gh; gh auth login).

# After each task integrates (CI green), refresh the running product so the live site
# matches main — rebuild the dashboard + restart both launchd agents. (Loopback-only; safe.)
: "${INTEGRATE_HOOK:=bash .harness/integrate.sh}"
