# .harness/config/harness.env — config for the in-place Ralph loop (sourced by scripts/loop.sh).
#
# Precedence:  real environment  >  this file  >  loop.sh built-in default
# (the `: "${VAR:=…}"` form only assigns when VAR is unset).

# ─── Model (COLD-START FLOOR — cheapest tier; the policy tunes UP from here) ──
# Tasks no longer carry per-task model/effort; the policy picks each task's start tier from
# facets + the outcomes ledger, cold-starting at this floor. Pin the FULL id (the bare alias drifts).
: "${MODEL:=claude-haiku-4-5}"
: "${EFFORT:=}"           # low|medium|high|xhigh|max, or empty — Haiku 4.5 has no effort parameter, so the floor is effort-less (bias-cheap; the ladder escalates)

# ─── Caps & cadence ──────────────────────────────────────────────────────────
: "${MAX_ATTEMPTS:=2}"     # soft failures per rung before escalating (global ladder is fine-grained, so fewer tries per rung bounds the attempt budget)
: "${MAX_ITERS:=100}"      # global iteration backstop per run
: "${WAIT_SECONDS:=30}"    # backoff between retries / CI polls
: "${CI_TIMEOUT:=1200}"    # max seconds to wait for a CI run

# ─── CI gate ─────────────────────────────────────────────────────────────────
: "${CI_WORKFLOW:=CI}"     # MUST equal `name:` in .github/workflows/ci.yml
: "${REQUIRE_CI:=1}"       # 1 = never mark a task done without green CI on main
: "${MAIN_BRANCH:=main}"

# ─── Workflow YAML lint (actionlint) ──────────────────────────────────────────
# structural_checks runs actionlint on any changed .github/workflows/*.yml BEFORE the push — catches
# a file that's valid YAML but invalid per GitHub Actions' own schema (kills the whole CI run at parse
# time), which LOCAL_DOD can't catch. Best-effort: warn+skip if the binary can't be fetched (offline).
: "${LINT_WORKFLOW_FILES:=1}"     # 0 disables the local gate (the lint-workflows.yml CI job still catches it)
: "${ACTIONLINT_VERSION:=1.7.12}"

# ─── Self-healing repo state (this checkout is OWNED by the loop) ────────────
# On a DIRTY tree at startup (almost always orphaned partial work from an attempt killed mid-build —
# e.g. a usage-limit interrupt — NOT human work), auto-STASH it (timestamped, recoverable via
# `git stash list`) then hard-reset to origin/$MAIN_BRANCH, so an unattended run can ALWAYS start
# instead of refusing forever. Set 0 to restore the protective "refuse on dirty tree" behaviour
# (correct for a checkout you also hand-edit). Default ON here: this is a dedicated loop checkout.
: "${LOOP_AUTORESET:=1}"

# ─── Local Definition-of-Done gate (cheap, runs BEFORE the paid audit) ────────
# The loop's structural_checks runs this in the checkout before the blocking audit, so a build
# that doesn't compile / pass tests never reaches the (paid) auditor. Mirror CI's core checks.
# See .harness/docs/designs/audit-verification.md §4.2.
: "${LOCAL_DOD:=npx tsc --noEmit && npm test}"

# ─── Claude usage-limit backoff (pause + cold re-attempt) ────────────────────
# When `claude` hits the usage/session limit, the loop SLEEPS then RE-ATTEMPTS the same task COLD
# (not a failure — every attempt is a fresh cold pass; §4.1). Two paths:
#  • KNOWN reset — Claude prints e.g. "resets 3:10pm (Europe/London)" → sleep until that time +
#    RL_BUFFER, then resume (the common case; this is why we don't blindly retry every few minutes).
#  • UNKNOWN reset (unparseable wording) → exponential backoff from RL_BACKOFF_MIN, doubling, capped
#    at RL_EXP_MAX.
: "${RL_BACKOFF_MIN:=300}"     # exponential-fallback FIRST backoff: 5 min
: "${RL_EXP_MAX:=3600}"        # exponential-fallback CAP: 1h (UNKNOWN-reset path only)
: "${RL_BACKOFF_MAX:=18000}"   # cap for a PARSED reset wait (~5h — a known reset can be hours away)
: "${RL_BUFFER:=300}"          # resume this many seconds AFTER a parsed reset time (5-min cushion)

# NOTE: jq + gh are required (brew install jq gh; gh auth login).

# After each task integrates (CI green), refresh the running product so the live site
# matches main — rebuild the dashboard + restart both launchd agents. (Loopback-only; safe.)
: "${INTEGRATE_HOOK:=bash .harness/scripts/integrate.sh}"

# ─── Scope-creep exemptions (files always allowed regardless of a task's scope) ─
# The dashboard visual-check harness scripts are always in-scope for a UI task (a layer:ui task
# must keep them current), so exempt them from the structural scope gate.
: "${SCOPE_EXEMPT_GLOBS:=dashboard/scripts/_dashboard-harness.mjs dashboard/scripts/visual-check.mjs dashboard/scripts/mobile-check.mjs}"

# ─── Visual verification (UI tasks) ──────────────────────────────────────────
# The loop injects a "run the hook + LOOK at the screenshots" block into the builder + auditor
# prompts for visual tasks; the project-specific richness lives in custom/visual-verify-*.md.
# This project's visual surface is the dashboard (facets.layer == ui).
: "${VISUAL_VERIFY_HOOK:=npm --prefix dashboard run build && node dashboard/scripts/visual-check.mjs}"
: "${VISUAL_VERIFY_LAYERS:=ui}"                          # facet layer(s) that auto-fire visual verification
: "${VISUAL_VERIFY_WORKTYPES:=component style}"          # inherently-visual work-types (fire on any layer)
: "${VISUAL_VERIFY_SKIP_WORKTYPES:=docs config logging}" # never auto-fire on these

# ─── Rate-limit / push / supervise cadence backstops (read by the pristine loop) ─
: "${RL_POLL:=900}"                # audit-path poll interval when a reset time can't be parsed
: "${RL_MAX_WAIT:=21600}"          # total usage-limit wait budget before exit-5 (→ supervise retries)
: "${PUSH_COOLDOWN_SECONDS:=0}"    # min seconds between integration pushes (0 = no throttle)
: "${RETRY_INTERVAL:=900}"         # supervise cadence after an exit-5 (rate-limit give-up) — retry soon
: "${SYNC_PRIMARY_ON_DONE:=1}"     # (worktree variant only — no effect on this in-place install)

# ─── Escalation-ladder resume across a loop.sh restart ──────────────────────
: "${LOOP_HEARTBEAT_RESUME_MAX_AGE:=21600}"  # a leftover heartbeat older than this (~6h) is ignored as stale; ladder cold-starts
: "${LOOP_IGNORE_HEARTBEAT:=}"               # set to 1 for one run to force a clean cold restart, ignoring any leftover heartbeat

# ─── Harness backlog dashboard (.harness/dashboard/server.js) ────────────────
: "${HARNESS_DASHBOARD_PORT:=4791}"          # 127.0.0.1 only; distinct from app 4788 / daemon 4789 (and the 4790 default, so multi-project dashboards don't collide)
: "${HARNESS_DASHBOARD_FETCH_SECONDS:=0}"    # 0 = no periodic git fetch by the dashboard

# ─── Console output ──────────────────────────────────────────────────────────
# 1 = echo the exact prompt handed to Claude to the console (stderr), wrapped in a heavy `=` banner,
# right before each invocation — so you can read what the agent was actually asked. Only the phase that
# is actually running prints: the BUILD prompt on a build, the AUDIT prompt only when a sampled task
# audits (never both preemptively). 0 = silence it (the streamed agent output still shows).
: "${PRINT_PROMPT:=1}"
