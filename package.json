{
  "name": "local-jobs",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Local job orchestrator + dashboard for the Mac Mini",
  "scripts": {
    "daemon": "tsx src/daemon.ts",
    "dev": "tsx watch src/daemon.ts",
    "run-job": "tsx src/runJob.ts",
    "db:reset": "tsx src/db/reset.ts",
    "harness:dashboard": "HARNESS_DASHBOARD_PORT=4792 node .harness/dashboard/server.js",
    "harness:start": "bash .harness/scripts/supervise.sh",
    "typecheck": "tsc --noEmit",
    "test": "rm -f /tmp/lj-test.db* 2>/dev/null; LOCALJOBS_DB=/tmp/lj-test.db tsx scripts/run-tests.ts"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.840.0",
    "@aws-sdk/lib-dynamodb": "^3.840.0",
    "@google/genai": "^2.9.0",
    "better-sqlite3": "^11.8.1",
    "croner": "^8.1.2",
    "csv-parse": "^5.6.0",
    "dotenv": "^17.4.2",
    "playwright": "^1.61.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
