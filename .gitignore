# --- Secrets: NEVER commit credentials ---
# Secrets live in .env (read via process.env). Only .env.example is tracked.
.env
.env.*
!.env.example
*.pem
*.key
*.p12
credentials.json
aws-credentials*
gcp-*.json
service-account*.json

# --- Private jobs: the framework is public, your jobs are not ---
# Only the demo example is tracked; every real job stays local-only.
src/workflows/*.job.ts
src/workflows/*.job.js
!src/workflows/demo.job.ts
# Workflow subfolders are private business logic. The places + perfumes pipeline
# code is now published (only their data/ stays ignored, below).
# Per-job resources/datasets live in the job's own data/ folder — never published.
src/workflows/**/data/

# --- Dependencies / build output ---
node_modules/
.next/
dist/
dashboard/next-env.d.ts
*.tsbuildinfo

# Ephemeral screenshots from dashboard/scripts/visual-check.mjs — regenerated each run,
# never committed (binary churn + the no-data-folder privacy rule).
dashboard/scripts/visual-out/

# --- Runtime data (SQLite + logs); keep the dir, drop its contents ---
data/*
!data/.gitkeep

# --- OS / misc ---
.DS_Store
*.log

# Personal running backlog (references private job work)
TODO.md

# --- Ralph build harness: transient scratch only ---
# The backlog (.harness/tracking/TASKS.json) and per-task worklog ARE committed; only the loop's
# transient scratch is ignored.
.harness/worklog/.result
.harness/worklog/.claude-out*
.harness/worklog/STATUS.md
.harness/worklog/*.audit.md
.harness/worklog/.failures.buf
.harness/worklog/.current.json
.harness/worklog/.local-dod.log

# The ideas inbox is a PRIVATE, transient capture scratchpad (raw, unfleshed ideas —
# may reference private jobs). The mechanism travels via .harness/CLAUDE.md; the ideas
# themselves stay local and are DELETED once converted into a TASKS.json task.
.harness/tracking/IDEAS.jsonl

# /local-jobs-convert-ideas scratch: per-unit agents each write one file here (decided task
# data, no id yet) instead of racing for the repo lock; a single consolidation pass allocates
# ids + commits, then deletes the consumed files. Never committed — see the skill's Stage 2/3.
.harness/.pending-tasks/

# /local-jobs-convert-ideas scratch: a per-unit agent blocked on a genuine open question (it has
# no AskUserQuestion — that's main-thread-only) writes its questions here durably BEFORE ending
# its turn, so the question survives even if the coordinating session ends before relaying it to
# the owner. Deleted once the unit is unblocked and finishes shaping. Never committed — see the
# skill's Stage 0/2.
.harness/.pending-questions/

# implementation-harness-fix-scope-gaps scratch: a dismissed check-task-scope.sh false-positive
# warning is recorded here (keyed by task id, with the spec's content hash) so pre-loop-checkin
# doesn't re-flag it every run. A stale dismissal (spec edited since) simply stops matching and
# the warning re-surfaces on its own. Never committed.
.harness/.scope-gap-ignores/*
!.harness/.scope-gap-ignores/.gitkeep

# harness: atomic-write temps for TASKS.json + the owner-owned reviews store (T136).
# .harness/tracking/reviews.json itself IS committed (owner-owned; the daemon commits+pushes it).
.harness/tracking/TASKS.json.tmp
.harness/tracking/reviews.json.tmp*

# --- Private scratch: plex-language-fix (personal library maintenance script, not a public example).
# Deliberately kept at the repo ROOT, not under src/workflows/, while another session is actively
# restructuring that directory — avoids collision with unrelated concurrent work. ---
/plex-language-fix/

# >>> implementation-harness managed (auto-maintained — do not edit inside) >>>
# Transient loop scratch (last-iteration verdict) + the generated status board.
.harness/worklog/.result
.harness/worklog/.claude-out*
.harness/worklog/.failures.buf
.harness/worklog/.current.json
.harness/worklog/STATUS.md
.harness/worklog/*.log
.harness/worklog/*.audit.md
# atomic-write temps (TASKS.json + the owner-overlay files never keep a crashed-mid-write file)
.harness/tracking/*.tmp
.harness/tracking/*.tmp.*
# ideas->tasks pipeline — ephemeral per-sweep scratch (the .gitkeep keeps each dir in a fresh clone)
.harness/.pending-tasks/*
!.harness/.pending-tasks/.gitkeep
.harness/.pending-questions/*
!.harness/.pending-questions/.gitkeep
# scope-gap dismissals — check-task-scope.sh's per-task "already reviewed" record (fix-scope-gaps)
.harness/.scope-gap-ignores/*
!.harness/.scope-gap-ignores/.gitkeep
# <<< implementation-harness managed <<<
