# Copy to .env and adjust as needed. All optional.

# Port for the orchestrator's localhost HTTP API (dashboard reads from this).
LOCALJOBS_PORT=4789

# Absolute path to the SQLite DB file (defaults to ./data/jobs.db).
# LOCALJOBS_DB=/Users/ryankrol/Development/local-jobs/data/jobs.db

# ntfy.sh topic for push alerts on job failure. Leave blank to disable push
# (failures are always still recorded in the dashboard + a macOS notification).
LOCALJOBS_NTFY_TOPIC=
# LOCALJOBS_NTFY_SERVER=https://ntfy.sh

# ── perfumes job ──
# Path to the profile output template the build stage enforces. Defaults to the
# in-project src/jobs/perfumes/profile.template.md; override to point elsewhere.
# PERFUMES_TEMPLATE_PATH=/path/to/_TEMPLATE.md
