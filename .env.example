# Copy to .env and adjust as needed. All optional.

# Port for the orchestrator's localhost HTTP API (dashboard reads from this).
LOCALJOBS_PORT=4789

# API bind address. Default 127.0.0.1 (loopback-only — not reachable off the box).
# Set to an interface address (e.g. a Tailscale IP) ONLY for remote access, and
# then set LOCALJOBS_TOKEN below so mutating endpoints require it.
# LOCALJOBS_HOST=127.0.0.1

# CORS allowlist (comma-separated). Never '*'. Defaults to the local dashboard
# origins; add a remote dashboard origin here if you expose the API.
# LOCALJOBS_ALLOWED_ORIGINS=http://localhost:4788,http://127.0.0.1:4788

# Shared secret guarding mutating endpoints (run/toggle/prune/…) for non-loopback
# callers. Blank = mutations accepted from loopback only. Set this when exposing
# the API remotely; callers send it as 'X-LocalJobs-Token' or 'Authorization: Bearer'.
# LOCALJOBS_TOKEN=

# ── dashboard (remote access over Tailscale) ──
# The dashboard SERVER proxies /api/* to this loopback API (default below). Keep
# it loopback so the API is never exposed; a remote browser talks only to the
# dashboard origin. Override only if the API moves host/port.
# LOCALJOBS_API_UPSTREAM=http://127.0.0.1:4789
# Absolute API base for the dashboard BROWSER. Blank = same-origin (proxied
# through the dashboard), the recommended default. Set only to point the browser
# at a directly-exposed API instead of the proxy.
# NEXT_PUBLIC_API_BASE=

# Absolute path to the SQLite DB file (defaults to ./data/jobs.db).
# LOCALJOBS_DB=/Users/ryankrol/Development/local-jobs/data/jobs.db

# Absolute path to the shared persistent Chrome profile used by all headless-browser
# scrape jobs (defaults to ./data/chrome-profile). Override only if you need a
# non-default location; the default is gitignored and shared across all scrapers.
# LOCALJOBS_CHROME_PROFILE=/path/to/chrome-profile

# ntfy.sh topic for push alerts on job failure. Leave blank to disable push
# (failures are always still recorded in the dashboard + a macOS notification).
LOCALJOBS_NTFY_TOPIC=
# LOCALJOBS_NTFY_SERVER=https://ntfy.sh

# ── perfumes job ──
# Path to the profile output template the build stage enforces. Defaults to the
# in-project src/jobs/perfumes/profile.template.md; override to point elsewhere.
# PERFUMES_TEMPLATE_PATH=/path/to/_TEMPLATE.md

# ── missing-tv-seasons workflow (Plex TV new-seasons audit) ──
# Your Plex server base URL (it uses a self-signed cert — the job scopes the TLS
# bypass to Plex requests only, never globally). If this goes stale (e.g. the
# server's DHCP lease changed its IP), the client self-heals by scanning the local
# subnet for a Plex on :32400 — but setting PLEX_HOST avoids that scan.
# PLEX_HOST=https://192.168.1.x:32400
# Plex API token (X-Plex-Token). Keep secret — never commit.
# PLEX_API_TOKEN=
# Optional: the server's machine identifier. When set, BOTH the PLEX_HOST check and
# the LAN scan only accept a Plex with THIS identifier — so a changed DHCP IP is
# self-healed without ever latching onto the wrong Plex on the network.
# PLEX_MACHINE_ID=
# The TV library section id to audit. Default 5.
# PLEX_TV_SECTION=5
# The MOVIE library section id to audit (the movies franchise-gap workflow). Default 4.
# PLEX_MOVIE_SECTION=4
# Optional Plex request timeout (ms). Default 30000.
# PLEX_REQUEST_TIMEOUT_MS=30000
# Optional LAN-scan tuning (used only when PLEX_HOST is stale/unset):
# PLEX_PROBE_TIMEOUT_MS=1500   # per-host probe timeout during a scan
# PLEX_SCAN_CONCURRENCY=32     # how many subnet hosts to probe at once
# PLEX_SCAN_CAP_MS=20000       # overall wall-clock cap so a no-Plex LAN fails fast
# TMDB v3 Bearer token (free API). Legacy TVDB_API_TOKEN is accepted as a fallback.
# TMDB_API_TOKEN=
# Optional: TMDB self-imposed pace (calls per rolling minute). Default 600 (~10/s).
# TMDB_RATE_PER_MIN=600
# ── movies recommendation layer (8 Claude recommender branches, T146) ──
# The (free) Claude model the recommender branches use. Default claude-sonnet-4-6.
# MOVIES_RECS_MODEL=claude-sonnet-4-6
# Owned-library sample size shown to each branch (stratified). Default 50.
# MOVIES_RECS_SAMPLE=50
# How many films each branch is asked for — headroom after filtering (T162). Default 9.
# MOVIES_RECS_PER_BRANCH_ASK=9
# Target size of the final balanced recommendation list (≥15, T162). Default 15.
# MOVIES_RECS_TARGET=15
# Max recommendations per genre in the balanced output. Default 3.
# MOVIES_RECS_GENRE_CAP=3
# Quality bar (T162): min TMDB vote_average to keep a rec. Default 7.0.
# MOVIES_RECS_MIN_RATING=7.0
# Quality bar (T162): min TMDB vote_count so the rating is meaningful. Default 50.
# MOVIES_RECS_MIN_VOTES=50
# Bounded merge top-up rounds when under target (T162). Default 3.
# MOVIES_RECS_TOPUP_ROUNDS=3
# How many recent recommendations to feed back into branch prompts. Default 40.
# MOVIES_RECS_RECENT_WINDOW=40
# Shared Claude Code CLI helper (src/services/claude.ts): CLI binary + per-call
# timeout (ms). Defaults: claude / 300000. (Perfumes keeps its own PERFUMES_CLAUDE_*.)
# LOCALJOBS_CLAUDE_BIN=claude
# LOCALJOBS_CLAUDE_TIMEOUT_MS=300000

# --- DynamoDB ingestion pipelines (workouts/projects) ---
# AWS creds for the shared dynamodb service (T252) + the sync workflows (T253/256).
# Use a LEAST-PRIVILEGE IAM key (read+write only the tables below). Region: e.g. us-east-2.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
# Existing tables (reused from the website): workouts pipeline (T253)
WORKOUTS_TABLE=Workouts
EXERCISES_TABLE=Exercises
# NEW table — create in AWS, then set the name: projects (T256)
PROJECTS_TABLE=
# Per-source API creds for the sync workflows
HEVY_API_KEY=
GITHUB_USERNAME=
# GitHub personal access token (at least `public_repo` scope). Without this,
# the github service falls back to unauthenticated requests (60 req/hr — fine
# for a single daily run, but set a token to be safe).
GITHUB_TOKEN=
# Optional: override per-minute rate / daily / monthly caps for the github service.
# GITHUB_RATE_PER_MIN=30
# GITHUB_DAILY_CAP=200
# GITHUB_MONTHLY_CAP=3000

# --- listening-digest workflow ---
# Monthly top-albums/top-tracks markdown digest — no DynamoDB, no per-scrobble sync.
LAST_FM_API_KEY=
LAST_FM_USERNAME=
# Optional: override the lastfm service's per-minute rate limit (default 30, free API).
# LASTFM_RATE_PER_MIN=30
